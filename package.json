{
  "name": "sketchguess-bench-workspace",
  "private": true,
  "workspaces": [
    "bench",
    "visualizer"
  ],
  "packageManager": "bun@1.2.0",
  "scripts": {
    "bench:run": "cd bench && bun run run",
    "bench:retry-word": "cd bench && bun run retry-word",
    "bench:models": "cd bench && bun run models",
    "dev:visualizer": "cd visualizer && bun run dev",
    "build:visualizer": "cd visualizer && bun run build",
    "generate:visualizer-data": "cd bench && bun run generate:visualizer-data"
  }
}
